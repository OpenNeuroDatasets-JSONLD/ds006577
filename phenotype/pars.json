    "anxiety_symptoms_number": {
        "Description": "1. Overall Number of Anxiety Symptoms (past week only)\t",
        "Levels": {
            "0": "No symptoms",
            "1": "1 symptom",
            "2": "2-3 symptoms",
            "3": "4-6 symptoms",
            "4": "7-10 symptoms",
            "5": "More than 10 symptoms",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
    "anxiety_symptoms_freq": {
        "Description": "2. Overall Frequency of Anxiety Symptoms",
        "Levels": {
            "0": "None",
            "1": "1-2 days per week",
            "2": "3-4 days per week",
            "3": "5-6 days per week (not daily)",
            "4": "Every day",
            "5": "Several hours every day",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
    "anxiety_feeling_severity": {
        "Description": "3. Overall Severity of Anxiety Feelings (past week only)  ",
        "Levels": {
            "0": "None. No anxious symptoms.",
            "1": "Minimal. Very transient discomfort.  Not clinically significant.",
            "2": "Mild. Transient discomfort that is mildly disturbing. Borderline clinical significance. Intermediate between 1 & 3.",
            "3": "Moderate. Clearly nervous when anticipating or confronting the anxiety-provoking situation(s). Often unable to overcome these feelings. These feelings impact on well-being.",
            "4": "Severe. Very distressed when anxious or when anticipating or confronting the anxiety-provoking situation(s). Usually unable to overcome this feeling. Intermediate between 3 & 5.",
            "5": "Extreme. Feels wretched when anticipating or confronting anxiety-provoking situation(s). Often totally or almost totally unable to overcome this fear. Very marked impact on well-being.",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
    "anxiety_physical_symp_severe": {
        "Description": "4. Overall Severity of Physical Symptoms of Anxiety  ",
        "Levels": {
            "0": "None. No physical symptoms",
            "1": "Minimal. Very transient physical symptoms of anxiety. Symptoms are not or are hardly noticeable       by others. Not clinically significant.",
            "2": "Mild. Few physical symptoms: no lasting impact. Borderline clinical significance. Intermediate between 1 & 3.",
            "3": "Moderate. Persistent physical symptoms of anxiety especially during exposure to the feared situation(s). Symptoms are noticeable by others and significantly interfere with his/her ability to function in the situation.",
            "4": "Severe. Marked physical symptoms of substantial clinical significance. Intermediate between 3 & 5.",
            "5": "Extreme. Severe and persistent physical symptoms of anxiety especially during exposure to the        feared situation(s). Symptoms are very obvious to others and often result in inability to        function in the situation.",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
    "anxiety_situation_avoid": {
        "Description": "5. Overall Avoidance of Anxiety-Provoking Situations (past week only) ",
        "Levels": {
            "0": "None. Does not avoid the anxiety-provoking situation(s).",
            "1": "Minimal. Very occasionally avoids the anxiety-provoking situation(s). Avoided situation(s) is/are not critical to his/her well-being.",
            "2": "Mild. Avoids anxiety-provoking situation(s) some of the time but no important situation is consistently avoided. Borderline clinical significance. Intermediate between 1 and 3.",
            "3": "Moderate. Avoids anxiety-provoking situation(s) frequently. At least one important situation is avoided.",
            "4": "Severe. Avoids anxiety-provoking situation most of the time or more than one important situation is consistently avoided. Intermediate between 3 & 5.",
            "5": "Extreme. Avoids all or almost all anxiety-provoking situations.",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
    "interfere_fmly_relationship": {
        "Description": "6. Interference with Family Relationships and/or Performance at Home",
        "Levels": {
            "0": "None. No interference.",
            "1": "Minimal. Very transient interference. No impact on relationships with family members or performance (tasks etc.) at home.",
            "2": "Mild. Slight impact on relationships with family members and performance at home. Borderline clinical significance. Intermediate between 1 and 3.",
            "3": "Moderate. Clear interference. Either performance of tasks at home or freq. or qual. of interaction w/ family members is affected: s/he might withdraw from interaction might be avoided/rejected by family members or might have many conflicts w/ them.",
            "4": "Severe. Marked interference in relationships with family members and/or performance at home. Of substantial clinical significance. Intermediate between 3 and 5.",
            "5": "Extreme. Totally or almost totally unable to maintain appropriate family relationships and/or to function at home.",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
    "interfere_peer_adult_relation": {
        "Description": "7. Interference with Peer and Adult Relationships and/or Performance Outside of Home.  ",
        "Levels": {
            "0": "None. No interference.",
            "1": "Minimal. Very transient interference. No impact on relationships with peers or teachers or other adults outside of the home. No impact on functioning outside of home e.g. attending and performing group activities.",
            "2": "Mild. Slight impact on relationships or performance outside of the home. Borderline clinical significance. Intermediate between 1 and 3.",
            "3": "Moderate. Clear interference. Either performance outside the home or frequency or quality of peer or adult interactions is affected: s/he might withdraw from interaction might be avoided/rejected by peers or adults or might have conflicts w/ them.",
            "4": "Severe: Marked interference in relationships with peers or adults outside of home and/or performance outside of home. Of substantial clinical significance. Intermediate between 3 and 5.",
            "5": "Extreme: Totally or almost totally unable to maintain appropriate peer or adult relationships and/or to function outside of home.",
            "8": "Not applicable",
            "9": "Does not know"
        }
    },
